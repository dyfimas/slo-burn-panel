{
  "name": "slo-burn-panel",
  "version": "0.1.3",
  "description": "Grafana panel plugin for SLO burn rate tracking with multi-window analysis and error budget visualization",
  "author": "Dylan Fiego",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "sign": "npx @grafana/sign-plugin@latest"
  },
  "overrides": {
    "serialize-javascript": "7.0.4"
  },
  "devDependencies": {
    "@grafana/data": "^11.0.0",
    "@grafana/runtime": "^11.0.0",
    "@grafana/schema": "^11.0.0",
    "@grafana/ui": "^11.0.0",
    "@swc/core": "^1.7.0",
    "copy-webpack-plugin": "^12.0.0",
    "fork-ts-checker-webpack-plugin": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "swc-loader": "^0.2.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.0",
    "webpack-livereload-plugin": "^3.0.0"
  }
}
